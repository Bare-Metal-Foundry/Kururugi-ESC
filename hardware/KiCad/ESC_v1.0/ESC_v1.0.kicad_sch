	)
	(text "General:\nHere we set OUT=(1A,10V), VIN=[4S, 6S]=[12, 60]V (ripple)\n---------------\nSwitching:\nFSW = min(FSW_max@VIN_min, FSW_max@VIN_max) = 981kHz\nRON = VOUT/FSW*10^10 = 110kR  (TON=458ns)\nCOT type BUCK: SW node high for TON if FB<REF.\n---------------\nInductor:\nL=VOx(VIN_max-VO)/(VIN_max*FSW*IO_max*0.4)=18µH.\n---------------\nOther:\nSoft Start: CSS=1µF => TSS=200ms.\nFeedback: 10V to 2V => RFB2/RFB1=4, we chosed \nHysteresis: VIN=18V, ΔVIN=2.5V so RUV2=124kR/RUV1=9.31kR\nAlim: CVCC is recommended to be 1µF/CBOOST to be 10nF."
		(exclude_from_sim no)
		(at 92.71 64.262 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left top)
		)
		(uuid "7d3115d8-cd98-4f82-adf6-2a4b6f035e4c")
	)
